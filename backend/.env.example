
# NARRIFY PHASE 1 - ENVIRONMENT CONFIGURATION


# Copy this file to .env and customize for your environment


# APPLICATION SETTINGS


APP_NAME=Narrify Phase 1
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO


# API SETTINGS


API_V1_PREFIX=/api
HOST=0.0.0.0
PORT=8000
RELOAD=True

# CORS Settings (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000


# FILE UPLOAD SETTINGS


MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
UPLOAD_TIMEOUT=300  # 5 minutes


# TTS MODEL SETTINGS


TTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
TTS_CHUNK_SIZE=200  # words per chunk
TTS_SAMPLE_RATE=22050
USE_GPU=True  # Auto-detect GPU/MPS
TTS_LANGUAGE=en

# Voice Customization Defaults
DEFAULT_SPEED=1.0
DEFAULT_PITCH=0
DEFAULT_TONE=normal
MIN_SPEED=0.5
MAX_SPEED=2.0
MIN_PITCH=-12
MAX_PITCH=12


# PDF PROCESSING SETTINGS


MIN_CHAPTER_LENGTH=100  # minimum characters
MAX_CHAPTER_LENGTH=50000  # maximum characters


# AUDIO PROCESSING SETTINGS


AUDIO_FORMAT=wav  # wav or mp3
AUDIO_BITRATE=192k  # for MP3
NORMALIZE_AUDIO=True
TRIM_SILENCE=True
SILENCE_THRESHOLD=-50  # dB


# TEXT NORMALIZATION SETTINGS


NORMALIZE_NUMBERS=True
NORMALIZE_DATES=True
NORMALIZE_CURRENCY=True
NORMALIZE_ABBREVIATIONS=True


# PERFORMANCE SETTINGS


MAX_WORKERS=4  # concurrent processing
CACHE_ENABLED=True
CACHE_TTL=3600  # 1 hour


# LOGGING SETTINGS


LOG_ROTATION=100 MB
LOG_RETENTION=30 days


# SECURITY SETTINGS


SECRET_KEY=change-this-in-production-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Emotion Detection (NEW)
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base

# NLP (NEW)
SPACY_MODEL=en_core_web_sm
# NOTES


# - All paths are relative to backend/ directory
# - GPU/MPS is auto-detected if USE_GPU=True
# - Model will be downloaded on first run (~2GB)
# - Adjust TTS_CHUNK_SIZE based on available RAM
# - Set DEBUG=False in production
